{
  "name": "mcp-gdocs",
  "version": "1.3.0",
  "type": "module",
  "description": "MCP server for Google Docs, Drive & Comments (OAuth + Service Account)",
  "author": "Artem Zheleznov (https://github.com/iamtemazhe)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamtemazhe/mcp-gdocs.git"
  },
  "homepage": "https://github.com/iamtemazhe/mcp-gdocs#readme",
  "bugs": {
    "url": "https://github.com/iamtemazhe/mcp-gdocs/issues"
  },
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/index.js",
      "types": "./build/index.d.ts"
    }
  },
  "bin": {
    "mcp-gdocs": "build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "start": "node build/index.js",
    "auth": "node build/index.js auth",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "test": "node --import tsx --test tests/unit/*.test.ts",
    "test:integration": "bash tests/integration/run-all.sh",
    "test:integration-node": "bash tests/integration/run-all.sh ts",
    "test:drive": "bash tests/integration/run-all.sh drive",
    "test:docs": "bash tests/integration/run-all.sh docs",
    "test:tables": "bash tests/integration/run-all.sh tables",
    "test:markdown": "bash tests/integration/run-all.sh markdown",
    "test:images": "bash tests/integration/run-all.sh images",
    "test:comments": "bash tests/integration/run-all.sh comments"
  },
  "keywords": [
    "mcp",
    "google-docs",
    "google-drive",
    "google-comments",
    "mcp-server",
    "cursor",
    "claude"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "google-auth-library": "^9.15.1",
    "googleapis": "^146.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
